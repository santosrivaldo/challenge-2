# Quando definido (ex.: /api/v1), a SPA usa a API Rails em vez do mock em memória.
# Em `npm run dev`, o Vite reencaminha pedidos que começam por /api para o alvo em vite.config (predefinição: http://127.0.0.1:8080).
# VITE_API_BASE_URL=/api/v1

# Alvo do proxy Vite para o prefixo /api (Compose na 8080 ou Rails em http://127.0.0.1:3000).
# VITE_PROXY_TARGET=http://127.0.0.1:8080
